<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>شركة البحيرة العربية</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>شركة البحيرة العربية</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- 🔥 Location (REQUIRED FIX) -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>
	نحتاج إلى موقعك لعرض موقعك الحالي وتتبع الشاحنات والطلبات داخل التطبيق أثناء الاستخدام فقط.
	We use your location to display your current position and track trucks and orders while using the app.
	</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>
	يتم استخدام الموقع لتحسين دقة التتبع وتقديم تجربة أفضل داخل التطبيق.
	Location is used to improve tracking accuracy and provide a better user experience.
	</string>

	<!-- Microphone -->
	<key>NSMicrophoneUsageDescription</key>
	<string>
	نحتاج إلى الميكروفون لتسجيل الرسائل الصوتية داخل المحادثات.
	We use the microphone to record voice messages within chats.
	</string>

	<!-- Speech Recognition -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>
	نحتاج إلى إذن التعرف على الكلام لتحويل الصوت إلى نص داخل التطبيق.
	We use speech recognition to convert voice input into text within the app.
	</string>

	<!-- Camera -->
	<key>NSCameraUsageDescription</key>
	<string>
	نحتاج إلى الكاميرا لالتقاط الصور والفيديو وإرسالها داخل التطبيق.
	We use the camera to capture photos and videos for sharing within the app.
	</string>

	<!-- Photo Library -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>
	نحتاج إلى الوصول إلى الصور لاختيار المرفقات وإرسالها داخل التطبيق.
	We access your photo library to select and share media within the app.
	</string>

	<!-- Save to Photos -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>
	نحتاج إلى إذن لحفظ الصور والفيديو عند مشاركة المرفقات.
	We need permission to save photos and videos when sharing media.
	</string>

	<!-- Background Modes (Safe) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

</dict>
</plist>